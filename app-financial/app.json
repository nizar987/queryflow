{
  "expo": {
    "name": "Dompeto",
    "slug": "dompeto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "dompeto",
    "backgroundColor": "#0D0D1A",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dompeto.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Gunakan Face ID untuk membuka Dompeto dengan aman.",
        "NSCameraUsageDescription": "Digunakan untuk memfoto struk transaksi.",
        "NSPhotoLibraryUsageDescription": "Digunakan untuk memilih foto dari galeri."
      }
    },
    "android": {
      "package": "com.dompeto.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D1A"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Gunakan Face ID untuk membuka Dompeto."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Dompeto membutuhkan akses galeri untuk foto struk.",
          "cameraPermission": "Dompeto membutuhkan akses kamera untuk foto struk."
        }
      ],
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
